      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n  %% Style definitions\n  classDef process fill:#e8f5e9,stroke:#43a047,stroke-width:2px,color:#1b5e20;\n  classDef decision fill:#fff8e1,stroke:#f9a825,stroke-width:2px,color:#e65100;\n  classDef socket fill:#f3e5f5,stroke:#8e24aa,stroke-width:2px,color:#4a148c;\n  classDef errorState fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c;\n\n  %% Flow nodes\n  NewChapter[\&quot;Mangaka: Create New Chapter (Status: Draft)\&quot;] --&gt; CreatePages[\&quot;Mangaka: Initialize Pages &amp; upload Base Original Images\&quot;]\n  CreatePages --&gt; CreateTasks[\&quot;Mangaka: Create Production Tasks per Page\&quot;]\n  \n  subgraph TaskTypes [Production Task Types]\n    Inking[\&quot;Inking Nét vẽ\&quot;]\n    Background[\&quot;Background Nền\&quot;]\n    Tone[\&quot;Tone Sắc độ\&quot;]\n    Lettering[\&quot;Lettering Lời thoại\&quot;]\n    Effects[\&quot;Effects Hiệu ứng\&quot;]\n  end\n  CreateTasks --&gt; TaskTypes\n  \n  TaskTypes --&gt; AssignAssistants[\&quot;Assign Tasks to Assistants (Dedicated/Freelance)\&quot;]\n  AssignAssistants --&gt; AssistantClaim[\&quot;Assistant: Claim Task (Status: in_progress)\&quot;]\n  \n  subgraph StudioLive [Studio Live Workspace - Real-time Synchronization]\n    JoinWS[\&quot;Socket.IO handshake &amp; join Room &#39;chapter:chapterId&#39;\&quot;]\n    Presence[\&quot;Presence tracking (presence:joined/list)\&quot;]\n    CursorSync[\&quot;Cursor coordinate updates (cursor:move)\&quot;]\n    ObjectSync[\&quot;Canvas JSON updates (object:sync / document:update)\&quot;]\n    ObjectLock[\&quot;Coordinate lock on active elements (object:lock/unlock)\&quot;]\n    \n    JoinWS --&gt; Presence --&gt; CursorSync --&gt; ObjectSync --&gt; ObjectLock\n  end\n  \n  AssistantClaim --&gt; JoinWS\n  ObjectLock --&gt; AssistantSubmit[\&quot;Assistant: Submit completed layer image (Status: review)\&quot;]\n  \n  AssistantSubmit --&gt; MangakaVerify{\&quot;Mangaka: Approve Task?\&quot;}\n  \n  MangakaVerify --&gt;|Request revision| TaskReject[\&quot;Re-open Task with feedback (Status: in_progress)\&quot;]\n  TaskReject --&gt; JoinWS\n  \n  MangakaVerify --&gt;|Approve| TaskDone[\&quot;Task Completed (Status: done)\&quot;]\n  \n  TaskDone --&gt; CheckAllTasks{\&quot;Are all Chapter Tasks completed?\&quot;}\n  CheckAllTasks --&gt;|No| AssignAssistants\n  CheckAllTasks --&gt;|Yes| SharpComposite[\&quot;Sharp Service: compositePageLayers by layerOrder (z-index)\&quot;]\n  \n  SharpComposite --&gt; PreviewChapter[\&quot;Compile final page compositeImage PNGs\&quot;]\n  PreviewChapter --&gt; SubmitChapter[\&quot;Mangaka: Submit Chapter (Status: Reviewing)\&quot;]\n\n  class NewChapter,CreatePages,CreateTasks,AssignAssistants,AssistantClaim,AssistantSubmit,TaskDone,SharpComposite,PreviewChapter,SubmitChapter process;\n  class MangakaVerify,CheckAllTasks decision;\n  class JoinWS,Presence,CursorSync,ObjectSync,ObjectLock socket;\n  class TaskReject errorState;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="H11hYDJp3_vRrhRekCmu-1">
