  <diagram id="kMbjsombKfVh_QIfTyv4" name="Real-time Socket &amp; Authentication Flow">
    <mxGraphModel dx="3433" dy="1757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n  %% Style definitions\n  classDef client fill:#e0f7fa,stroke:#00acc1,stroke-width:2px,color:#004d40;\n  classDef server fill:#e8f5e9,stroke:#43a047,stroke-width:2px,color:#1b5e20;\n  classDef decision fill:#fff8e1,stroke:#f9a825,stroke-width:2px,color:#e65100;\n  classDef errorState fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c;\n\n  %% Flow nodes\n  ClientLogin[\&quot;Client Login / Registration Successful\&quot;] --&gt; GetToken[\&quot;Retrieve JWT Token and store locally\&quot;]\n  GetToken --&gt; InitSocket[\&quot;Client: Connect Socket.io client to Backend\&quot;]\n  InitSocket --&gt; SendAuthHandshake[\&quot;Send token via handshake.auth or query.token\&quot;]\n  \n  subgraph BE_Auth [Backend Socket.IO Auth Middleware]\n    VerifyToken{\&quot;Token valid?\&quot;}\n    SocketReject[\&quot;Reject connection (Error: Authentication required)\&quot;]\n    SocketAccept[\&quot;Accept connection &amp; bind socket.userId / socket.userRole\&quot;]\n  end\n  \n  SendAuthHandshake --&gt; VerifyToken\n  VerifyToken --&gt;|No| SocketReject\n  VerifyToken --&gt;|Yes| SocketAccept\n  \n  subgraph RoomManager [Socket Room Registrations]\n    JoinPersonalRoom[\&quot;Socket joins personal room: &#39;user:userId&#39;\&quot;]\n    JoinRoleRoom[\&quot;Socket joins role-based room: &#39;role:userRole&#39;\&quot;]\n    BroadcastStatus[\&quot;Broadcast online status to peers: &#39;user:status&#39; = online\&quot;]\n  end\n  \n  SocketAccept --&gt; JoinPersonalRoom --&gt; JoinRoleRoom --&gt; BroadcastStatus\n  \n  BroadcastStatus --&gt; MainListener[\&quot;Socket Server starts listening to custom incoming events\&quot;]\n  \n  subgraph SocketEvents [Registered Custom Events]\n    E_JoinRoom[\&quot;join:room -&gt; Join a chapter drawing space room\&quot;]\n    E_Cursor[\&quot;cursor:move -&gt; Broadcast cursor coordinates to other room members\&quot;]\n    E_Sync[\&quot;object:sync -&gt; Broadcast canvas edits to other room members\&quot;]\n    E_Lock[\&quot;object:lock / object:unlock -&gt; Lock/unlock active shapes\&quot;]\n    E_Disconnect[\&quot;disconnect -&gt; Broadcast offline status &amp; clean room mappings\&quot;]\n  end\n  \n  MainListener --&gt; E_JoinRoom\n  MainListener --&gt; E_Cursor\n  MainListener --&gt; E_Sync\n  MainListener --&gt; E_Lock\n  MainListener --&gt; E_Disconnect\n\n  class ClientLogin,GetToken,InitSocket,SendAuthHandshake client;\n  class SocketAccept,JoinPersonalRoom,JoinRoleRoom,BroadcastStatus,MainListener,E_JoinRoom,E_Cursor,E_Sync,E_Lock,E_Disconnect server;\n  class VerifyToken decision;\n  class SocketReject errorState;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="1WlhxdLUtkrISbxNiegx-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="Backend Socket.IO Auth Middleware" mermaidId="n:BE_Auth" mermaidBaseStyle="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=top;fillColor=light-dark(#ffffde,#1f2020);strokeColor=light-dark(#aaaa33,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="Backend Socket.IO Auth Middleware" id="1WlhxdLUtkrISbxNiegx-2">
          <mxCell parent="1WlhxdLUtkrISbxNiegx-1" style="html=1;whiteSpace=wrap;strokeWidth=1;verticalAlign=top;fillColor=light-dark(#ffffde,#1f2020);strokeColor=light-dark(#aaaa33,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" vertex="1">
            <mxGeometry height="348" width="1020" x="1121" y="426" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="Token valid?" mermaidId="n:VerifyToken" mermaidBaseStyle="rhombus;html=1;strokeWidth=2;whiteSpace=wrap;fillColor=#fff8e1;strokeColor=#f9a825;fontColor=#e65100;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="Token valid?" id="1WlhxdLUtkrISbxNiegx-3">
          <mxCell parent="1WlhxdLUtkrISbxNiegx-2" style="rhombus;html=1;strokeWidth=2;whiteSpace=wrap;fillColor=#fff8e1;strokeColor=#f9a825;fontColor=#e65100;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" vertex="1">
            <mxGeometry height="155" width="155" x="445" y="45" as="geometry" />
          </mxCell>
