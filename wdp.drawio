        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n  %% Style definitions\n  classDef fe fill:#e0f7fa,stroke:#00acc1,stroke-width:2px,color:#004d40;\n  classDef mb fill:#ede7f6,stroke:#5e35b1,stroke-width:2px,color:#311b92;\n  classDef comm fill:#fff8e1,stroke:#ffb300,stroke-width:2px,color:#5d4037;\n  classDef be fill:#e8f5e9,stroke:#43a047,stroke-width:2px,color:#1b5e20;\n  classDef db fill:#ffebee,stroke:#e53935,stroke-width:2px,color:#7f0000;\n  \n  %% Client Layer\n  subgraph Client_Layer [\&quot;Client Tier\&quot;]\n    subgraph FE_App [\&quot;Web Frontend (FE - React + Vite)\&quot;]\n      fe_ui[\&quot;UI Components (Tailwind v4)\&quot;]\n      fe_studio[\&quot;Studio Workspace (Fabric.js)\&quot;]\n      fe_axios[\&quot;Axios Client\&quot;]\n      fe_socket[\&quot;Socket.io-Client\&quot;]\n    end\n    \n    subgraph MB_App [\&quot;Mobile App (MB - React Native + Expo)\&quot;]\n      mb_ui[\&quot;UI Navigation (Expo Router)\&quot;]\n      mb_studio[\&quot;Studio &amp; Task Screens\&quot;]\n      mb_axios[\&quot;Axios Client\&quot;]\n      mb_socket[\&quot;Socket.io-Client\&quot;]\n    end\n  end\n\n  %% Communication API Gateways\n  subgraph Comm_Layer [\&quot;Communication Tier\&quot;]\n    http_api[\&quot;HTTP REST API\&quot;]\n    ws_socket[\&quot;WebSocket Server (Socket.IO)\&quot;]\n  end\n\n  %% Backend Application\n  subgraph BE_App [\&quot;Backend Server (BE - Node.js + Express)\&quot;]\n    server_init[\&quot;Http Server &amp; server.ts\&quot;]\n    app_router[\&quot;Express App (app.ts)\&quot;]\n    \n    subgraph Middleware [\&quot;Express Middlewares\&quot;]\n      m_auth[\&quot;JWT Authenticate\&quot;]\n      m_rbac[\&quot;RBAC Guard\&quot;]\n      m_access[\&quot;Chapter Access Control\&quot;]\n      m_upload[\&quot;Multer Upload\&quot;]\n      m_validate[\&quot;express-validator\&quot;]\n    end\n    \n    subgraph Controllers [\&quot;Controllers\&quot;]\n      c_auth[\&quot;Auth Controller\&quot;]\n      c_series[\&quot;Series &amp; Chapter Controller\&quot;]\n      c_task[\&quot;Workflow Task Controller\&quot;]\n      c_review[\&quot;Editor/EB Review Controller\&quot;]\n      c_collab[\&quot;Zone &amp; Annotation Controller\&quot;]\n    end\n\n    subgraph Socket_Handlers [\&quot;Socket Events Hub\&quot;]\n      s_room[\&quot;Room Manager (Rooms: user:id, role:name, room:page)\&quot;]\n      s_presence[\&quot;Presence &amp; Cursor Sync\&quot;]\n      s_collab_sync[\&quot;Canvas Sync (Lock/Unlock/Update)\&quot;]\n    end\n    \n    subgraph Services [\&quot;Application Services\&quot;]\n      s_workflow[\&quot;Workflow Service (State Engine)\&quot;]\n      s_notify[\&quot;Notification Service (Socket + Database)\&quot;]\n      s_storage[\&quot;Storage Service (Local / Cloudflare R2)\&quot;]\n      s_scheduler[\&quot;Scheduler Service (Cron/Deadlines)\&quot;]\n    end\n  end\n\n  %% Data Layer\n  subgraph Data_Layer [\&quot;Data &amp; Storage Tier\&quot;]\n    subgraph Database [\&quot;MongoDB via Mongoose\&quot;]\n      m_user[\&quot;User Model\&quot;]\n      m_manga[\&quot;Series / Chapter / Page Models\&quot;]\n      m_task_db[\&quot;Task Model\&quot;]\n      m_feedback[\&quot;Zone / Annotation / Comment Models\&quot;]\n      m_eb[\&quot;Rubric Template / EBVote / Meeting Models\&quot;]\n    end\n    \n    subgraph Storage [\&quot;File Storage\&quot;]\n      local_upload[\&quot;Local upload/ folder\&quot;]\n      cf_r2[\&quot;Cloudflare R2 Bucket (Production)\&quot;]\n    end\n  end\n\n  %% Connections\n  fe_axios --&gt;|\&quot;HTTP (JSON / Form)\&quot;| http_api\n  mb_axios --&gt;|\&quot;HTTP (JSON / Form)\&quot;| http_api\n  fe_socket --&gt;|\&quot;WebSockets (Real-time)\&quot;| ws_socket\n  mb_socket --&gt;|\&quot;WebSockets (Real-time)\&quot;| ws_socket\n  \n  http_api --&gt; server_init\n  ws_socket --&gt; initSocket[\&quot;initSocket()\&quot;]\n  \n  server_init --&gt; app_router\n  \n  app_router --&gt; Middleware\n  Middleware --&gt; Controllers\n  \n  initSocket --&gt; Socket_Handlers\n  \n  Controllers --&gt; Services\n  Socket_Handlers --&gt; Services\n  \n  Services --&gt; Database\n  Services --&gt; Storage\n  \n  %% Style assignments\n  class fe_ui,fe_studio,fe_axios,fe_socket fe;\n  class mb_ui,mb_studio,mb_axios,mb_socket mb;\n  class http_api,ws_socket comm;\n  class server_init,app_router,m_auth,m_rbac,m_access,m_upload,m_validate,c_auth,c_series,c_task,c_review,c_collab,s_room,s_presence,s_collab_sync,s_workflow,s_notify,s_storage,s_scheduler be;\n  class m_user,m_manga,m_task_db,m_feedback,m_eb,local_upload,cf_r2 db;\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="GF5ePucWkJitNAmooKH7-1">
