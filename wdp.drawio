  <diagram id="XeI9fW6NaXBiKruMQj78" name="Series Lifecycle">
    <mxGraphModel dx="2575" dy="1318" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n  %% Style definitions\n  classDef startEnd fill:#eceff1,stroke:#37474f,stroke-width:2px,color:#263238;\n  classDef process fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1;\n  classDef decision fill:#fff8e1,stroke:#f9a825,stroke-width:2px,color:#e65100;\n  classDef errorState fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c;\n  classDef successState fill:#e8f5e9,stroke:#43a047,stroke-width:2px,color:#1b5e20;\n\n  %% Flow nodes\n  Start([Start]) --&gt; CreateSeries[\&quot;Mangaka: Create New Series (Status: Draft)\&quot;]\n  CreateSeries --&gt; AssignEditor[\&quot;Mangaka: Assign Tantou Editor (editorStatus: pending)\&quot;]\n  \n  AssignEditor --&gt; EditorAcceptDecision{\&quot;Editor: Accept Assignment?\&quot;}\n  \n  EditorAcceptDecision --&gt;|No| EditorRejected[\&quot;Editor Rejected (editorStatus: rejected)\&quot;]\n  EditorRejected --&gt; AssignEditor\n  \n  EditorAcceptDecision --&gt;|Yes| EditorAccepted[\&quot;Editor Accepted (editorStatus: accepted)\&quot;]\n  \n  EditorAccepted --&gt; AddDetails[\&quot;Mangaka: Fill script, character designs, and metadata\&quot;]\n  AddDetails --&gt; SubmitToEditor[\&quot;Mangaka: Submit Series for Review (Status: Pending_Editor)\&quot;]\n  \n  SubmitToEditor --&gt; EditorReview{\&quot;Editor: Approve Series?\&quot;}\n  \n  EditorReview --&gt;|Reject| EditorRejectSeries[\&quot;Editor Rejected (Status: Rejected)\&quot;]\n  EditorRejectSeries --&gt;|Rejection Notes| AddDetails\n  \n  EditorReview --&gt;|Approve| SubmitToEB[\&quot;Submit to Editorial Board (Status: Pending_EB)\&quot;]\n  \n  SubmitToEB --&gt; EBReviewProcess[\&quot;EB Review &amp; Assessment Flow\&quot;]\n  \n  subgraph EBReview [Editorial Board Review Process]\n    EBMeeting[\&quot;Hold Review Meeting (Meeting)\&quot;]\n    EBVote[\&quot;Cast Votes (EBVote)\&quot;]\n    EBRubric[\&quot;Evaluate via active Rubric Template\&quot;]\n    EBMeeting &amp; EBVote &amp; EBRubric\n  end\n  \n  EBReviewProcess --&gt; EBReview\n  EBReview --&gt; EBDecision{\&quot;Meets Vote &amp; Rubric Score Threshold?\&quot;}\n  \n  EBDecision --&gt;|No| EBReject[\&quot;Board Rejected (Status: Rejected)\&quot;]\n  EBReject --&gt;|Rejection Feedback| AddDetails\n  \n  EBDecision --&gt;|Yes| EBApprove[\&quot;Board Approved (Status: Active)\&quot;]\n  \n  EBApprove --&gt; MangakaWorkspace[\&quot;Series Active: Mangaka can now create Chapters\&quot;]\n  MangakaWorkspace --&gt; End([End])\n\n  class Start,End startEnd;\n  class CreateSeries,AssignEditor,EditorAccepted,AddDetails,SubmitToEditor,SubmitToEB,MangakaWorkspace process;\n  class EditorAcceptDecision,EditorReview,EBDecision,EBReviewProcess decision;\n  class EditorRejected,EditorRejectSeries,EBReject errorState;\n  class EBApprove successState;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="wyYvcMs9OgJSuC-rv3uP-22">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
