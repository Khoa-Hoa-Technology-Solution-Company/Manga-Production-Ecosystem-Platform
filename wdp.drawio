        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n  %% Style definitions\n  classDef process fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#e65100;\n  classDef decision fill:#fff8e1,stroke:#f9a825,stroke-width:2px,color:#e65100;\n  classDef errorState fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#b71c1c;\n  classDef successState fill:#e8f5e9,stroke:#43a047,stroke-width:2px,color:#1b5e20;\n\n  %% Flow nodes\n  ChapterInReview[\&quot;Chapter Submitted for Review (Status: Reviewing)\&quot;] --&gt; EditorOverlay[\&quot;Editor Portal: Load DraftReviewCanvas overlay\&quot;]\n  EditorOverlay --&gt; DrawFeedback[\&quot;Editor: Draw feedback Zones directly over manuscript pages\&quot;]\n  DrawFeedback --&gt; AddAnnotation[\&quot;Editor: Save details feedback notes (Annotations) &amp; page score\&quot;]\n  \n  AddAnnotation --&gt; EditorApproval{\&quot;Editor Approval?\&quot;}\n  \n  EditorApproval --&gt;|Reject| EditorReject[\&quot;Editor Rejected Chapter\&quot;]\n  EditorReject --&gt; RevertToDraft[\&quot;Chapter Status Reverted to Draft\&quot;]\n  RevertToDraft --&gt; NotifyMangaka[\&quot;Notify Mangaka &amp; re-open relevant tasks for correction\&quot;]\n  \n  EditorApproval --&gt;|Approve| ChapterApproved[\&quot;Chapter Approved (Status: Approved)\&quot;]\n  \n  ChapterApproved --&gt; CheckSchedule{\&quot;Is there a future Scheduled publicationDeadline?\&quot;}\n  \n  CheckSchedule --&gt;|Yes| WaitSchedule[\&quot;Wait until scheduled time (Scheduler Service - Cron Job)\&quot;]\n  CheckSchedule --&gt;|No| AutoPublishCheck{\&quot;Is parent Series Active and no future deadline?\&quot;}\n  \n  AutoPublishCheck --&gt;|Yes| PublishInstant[\&quot;Board Auto-Publish Chapter immediately\&quot;]\n  AutoPublishCheck --&gt;|No| EBFinalApprove{\&quot;Editorial Board: Publish manually?\&quot;}\n  \n  WaitSchedule &amp; PublishInstant --&gt; PublishChapter[\&quot;Chapter Published (Status: Published)\&quot;]\n  EBFinalApprove --&gt;|Yes| PublishChapter\n  \n  PublishChapter --&gt; PushNotification[\&quot;Send WebSocket &amp; DB notification to Series Subscribers\&quot;]\n\n  class ChapterInReview,EditorOverlay,DrawFeedback,AddAnnotation,ChapterApproved,WaitSchedule,PublishChapter,PushNotification process;\n  class EditorApproval,CheckSchedule,AutoPublishCheck,EBFinalApprove decision;\n  class EditorReject,RevertToDraft,NotifyMangaka errorState;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="FqaDGZf7kiyju1aZcETo-1">
