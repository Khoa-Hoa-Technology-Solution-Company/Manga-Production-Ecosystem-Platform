# Root environment example for the whole project
# Copy this file to .env in the app you are working on and fill in real values.

# Shared
NODE_ENV=development
APP_NAME=Manga Production Ecosystem Platform

# Frontend
VITE_API_BASE_URL=http://localhost:3000
VITE_APP_URL=http://localhost:5173

# Backend
PORT=3000
HOST=0.0.0.0
SESSION_SECRET=change-me
JWT_SECRET=change-me
DATABASE_URL=postgresql://user:password@localhost:5432/manga_platform

# Mobile / Expo
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_APP_ENV=development
